    <worksheet name='Revenue Integrity '>
      <table>
        <view>
          <datasources>
            <datasource caption='hotel_bookings' name='federated.1tkcgha060g3gd17sauzr14ny0i4' />
          </datasources>
          <datasource-dependencies datasource='federated.1tkcgha060g3gd17sauzr14ny0i4'>
            <column caption='Lead Time Bucket' datatype='string' name='[Calculation_0735928117612545]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [lead_time] &lt;= 7 THEN &quot;0-7&quot;&#10;ELSEIF [lead_time] &lt;= 30 THEN &quot;8-30&quot;&#10;ELSEIF [lead_time] &lt;= 90 THEN &quot;31-90&quot;&#10;ELSEIF [lead_time] &lt;= 180 THEN &quot;91-180&quot;&#10;ELSE &quot;180+&quot; &#10;END' />
            </column>
            <column caption='Realized Revenue' datatype='real' name='[Calculation_0735928119177222]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [is_canceled] = 0 &#10;THEN [adr] * ([stays_in_weekend_nights] + [stays_in_week_nights]) &#10;ELSE 0 &#10;END' />
            </column>
            <column caption='Lost Revenue' datatype='real' name='[Calculation_0735928119455752]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [is_canceled] = 1 &#10;THEN [adr] * ([stays_in_weekend_nights] + [stays_in_week_nights]) &#10;ELSE 0 &#10;END' />
            </column>
            <column caption='ADR' datatype='real' name='[adr]' role='measure' type='quantitative' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal' />
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column caption='Lead Time' datatype='integer' name='[lead_time]' role='measure' type='quantitative' />
            <column caption='Stays In Week Nights' datatype='integer' name='[stays_in_week_nights]' role='measure' type='quantitative' />
            <column caption='Stays In Weekend Nights' datatype='integer' name='[stays_in_weekend_nights]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0735928119177222]' derivation='Sum' name='[sum:Calculation_0735928119177222:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0735928119455752]' derivation='Sum' name='[sum:Calculation_0735928119455752:qk]' pivot='key' type='quantitative' />
